APP_NAME="Caronte ERP"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# Portas expostas pelo Docker Compose
APP_PORT=8000
FRONTEND_PORT=5173
FORWARD_DB_PGSQL_PORT=5432
FORWARD_REDIS_PORT=6379
FORWARD_MAILPIT_PORT=8025
FORWARD_MAILPIT_SMTP_PORT=1025

# URL pública do frontend — usada pelo CORS do backend
FRONTEND_URL=http://localhost:5173

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# PostgreSQL (padrão para Docker dev)
DB_CONNECTION=pgsql
DB_HOST=pgsql
DB_PORT=5432
DB_DATABASE=caronte
DB_USERNAME=caronte
DB_PASSWORD=secret

# MySQL local (sem Docker) — troque os valores acima por:
# DB_CONNECTION=mysql
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=caronte
# DB_USERNAME=root
# DB_PASSWORD=sua_senha

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=secret_redis

CACHE_STORE=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis

MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

BROADCAST_DRIVER=log
FILESYSTEM_DISK=local

XDEBUG_MODE=develop,debug
XDEBUG_CLIENT_HOST=host.docker.internal
XDEBUG_CLIENT_PORT=9003
