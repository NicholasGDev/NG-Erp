# =============================================================================
# front/Dockerfile.dev — Caronte ERP Frontend DEV (Vite HMR)
# Monta ./front como /workspace e inicia o dev server.
# =============================================================================
FROM node:22-alpine

WORKDIR /workspace

EXPOSE 5173

# npm install é executado no CMD para usar os pacotes do volume montado
CMD ["sh", "-c", "npm install --ignore-scripts && npm run dev"]
